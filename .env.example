# Copy to .env.local and fill in real values. Do not commit .env.local.

# CDS connection
NEXT_PUBLIC_CDS_BASE_URL=https://cds-beta.thepublive.com
NEXT_PUBLIC_CDS_PUBLISHER_ID=4027

# Publive CMS credentials (HTTP Basic auth against the CDS). Leave blank for
# endpoints that do not require authentication.
CDS_USERNAME=
CDS_PASSWORD=

# Active publisher key — selects branding/theme from src/config/publishers.ts
NEXT_PUBLIC_PUBLISHER_KEY=crictoday
