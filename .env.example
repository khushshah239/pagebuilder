# Copy values from this file into .env.local and fill in the secrets.
# .env.local is gitignored and overrides .env.development / .env.production.

NEXT_PUBLIC_CDS_BASE_URL=https://cds-beta.thepublive.com
NEXT_PUBLIC_CDS_PUBLISHER_ID=your_publisher_id_here

# HTTP Basic auth for CDS — server-only, never exposed to browser.
CDS_USERNAME=your_cds_username_here
CDS_PASSWORD=your_cds_password_here

# Selects branding/theme from src/config/publishers.ts
NEXT_PUBLIC_PUBLISHER_KEY=crictoday
